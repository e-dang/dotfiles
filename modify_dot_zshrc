#!/bin/bash

# Lines that must exist in ~/.zshrc. Each is checked individually —
# if already present the line is left where it is, otherwise it's appended.
MANAGED_LINES=(
  'eval "$(/opt/homebrew/bin/brew shellenv)"'
  'export NVM_DIR="$HOME/.nvm"'
  '[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm'
  '[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion'
  'source ~/.zsh/settings.zsh'
  'export SEARXNG_HOME="$HOME/.searxng"'
)

# Read current file contents from stdin
CURRENT=$(cat)

# Start with existing content
OUTPUT="$CURRENT"

# Append any managed lines that are missing
for line in "${MANAGED_LINES[@]}"; do
  if ! echo "$CURRENT" | grep -qF "$line"; then
    OUTPUT="$OUTPUT
$line"
  fi
done

echo "$OUTPUT"
