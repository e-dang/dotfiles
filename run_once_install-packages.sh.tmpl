{{- if contains "root" .profile -}}
#!/bin/bash

which -s brew
if [[ $? != 0 ]] ; then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew bundle --file=/dev/stdin <<EOF

tap "homebrew/cask-drivers"

brew "zsh"
brew "git"
brew "python"
brew "tree"
brew "parallel"
brew "nvm"
brew "yarn"
brew "pulumi"
brew "helm"
brew "k9s"
brew "fluxcd/tap/flux"
brew "argocd"
brew "awscli"
brew "sops"
brew "jq" # json cli parser
brew "yq" # yaml cli parser
brew "neovim"
brew "ripgrep"
brew "chezmoi"
{{ if eq .profile "root-osx" -}}
brew "coreutils"
brew "wget"
brew "azure-cli"
brew "gnupg"

cask "visual-studio-code"
cask "iterm2"
cask "google-chrome"
cask "rectangle"
cask "docker-desktop"
cask "spotify"
cask "figma"
cask "lm-studio"
cask "claude-code"
cask "ollama"
cask "obsidian"
cask "font-meslo-lg-nerd-font"
{{ end -}}

EOF
{{ end }}