remove_pycache() {
    find . | grep -E "(__pycache__|\.pytest_cache|\.pyc|\.pyo$)" | xargs rm -rf
}

# Utility for escaping parentheses and brackets when giving jest a filepath that contains them
# like when using nextjs or expo...fucking stupid file based routing bullshit
escape() {
    local input="$1"
    # Escape parentheses and brackets one by one
    echo "$input" | sed 's/(/\\(/g; s/)/\\)/g; s/\[/\\[/g; s/\]/\\]/g'
}

killport() {
  lsof -t -i tcp:$1 | xargs kill
}

init-notes() {
  local vault_type="${1:-local}"
  local target="${2:-.}"

  if [[ "$vault_type" != "local" && "$vault_type" != "global" ]]; then
    echo "Usage: init-notes [local|global] [target-path]"
    echo "  local   — repository-scoped vault with feature folders (default)"
    echo "  global  — flat knowledge base organized by tags"
    return 1
  fi

  local template_dir="$HOME/.config/obsidian/templates/$vault_type"
  if [[ ! -d "$template_dir" ]]; then
    echo "Template directory not found: $template_dir"
    echo "Run 'chezmoi apply' to deploy obsidian templates first."
    return 1
  fi

  mkdir -p "$target"
  cp -r "$template_dir"/* "$target/"
  echo "Initialized $vault_type vault at $target"
}

cpjs() { # cpjs -> copy javascript configs
  cp ~/.prettierrc.js $(pwd)
  cp $(chezmoi source-path)/eslintrc.js $(pwd)/.eslintrc.js
}

# Idempotently start Open WebUI in Docker and open it in the browser.
# Data is persisted to ~/.local/share/open-webui.
open-webui() {
  local name="open-webui"
  local port=8095
  local data_dir="$HOME/.local/share/open-webui"
  local image="ghcr.io/open-webui/open-webui:main"
  local url="http://localhost:${port}"

  if ! docker info >/dev/null 2>&1; then
    echo "Docker is not running. Start Docker Desktop and try again."
    return 1
  fi

  mkdir -p "$data_dir"

  local secret_file="${data_dir}/.webui_secret_key"
  if [[ ! -f "$secret_file" ]]; then
    openssl rand -hex 32 > "$secret_file"
    chmod 600 "$secret_file"
  fi

  local container_status
  container_status=$(docker inspect -f '{{`{{.State.Status}}`}}' "$name" 2>/dev/null)

  case "$container_status" in
    running)
      ;;
    "")
      echo "Creating $name container..."
      docker run -d \
        --name "$name" \
        -p "${port}:8080" \
        -v "${data_dir}:/app/backend/data" \
        -e "WEBUI_SECRET_KEY=$(<"$secret_file")" \
        --restart unless-stopped \
        "$image" >/dev/null || return 1
      ;;
    *)
      echo "Starting $name container..."
      docker start "$name" >/dev/null || return 1
      ;;
  esac

  echo "Waiting for ${url}..."
  local i=0
  until curl -fsS --max-time 2 "$url" >/dev/null 2>&1; do
    if (( i >= 120 )); then
      echo "Timed out waiting for ${url}"
      return 1
    fi
    sleep 1
    i=$((i + 1))
  done

  open "$url"
}

{{ if eq .profile "root-osx" -}}
LLVM_PATH=$(brew --prefix)/opt/llvm/bin
GCC_PATH=$(brew --prefix)/opt/gcc/bin

use_xcode() {
    export LDFLAGS=""
    path_remove $LLVM_PATH
    path_remove $GCC_PATH
    unalias_gcc
}

use_llvm() {
    export LDFLAGS="-L$(brew --prefix)/opt/llvm/lib -Wl,-rpath,$(brew --prefix)/opt/llvm/lib"
    path_remove $GCC_PATH
    path_prepend $LLVM_PATH
    unalias_gcc
}

use_gcc() {
    export LDFLAGS=""
    path_remove $LLVM_PATH
    path_prepend $GCC_PATH
    gcc=$(ls $GCC_PATH | grep "^gcc-\d\d$")
    gpp=$(ls $GCC_PATH | grep "^g++-\d\d$")
    alias gcc=$gcc
    alias cc=$gcc
    alias g++=$gpp
    alias c++=$gpp
}

unalias_gcc() {
    for name in gcc cc g++ c++; do
        if [[ $(alias | grep $name) ]]; then
            unalias $name
        fi
    done
}
{{ end }}